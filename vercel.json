{
  "version": 2,
  "builds": [
    {
      "src": "backend/server-unified.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/server-unified.js"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/build"
    }
  ],
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_ANON_KEY": "@supabase_anon_key"
  }
}
